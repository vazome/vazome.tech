{
    "mcp": {
        "inputs": [],
        "servers": {
            "context7": {
                "type": "stdio",
                "command": "npx",
                "args": [
                    "-y",
                    "@upstash/context7-mcp"
                ]
            },
            "browsermcp": {
                "type": "stdio",
                "command": "npx",
                "args": [
                    "@browsermcp/mcp@latest"
                ]
            },
            "github": {
                "type": "http",
                "url": "https://api.githubcopilot.com/mcp/"
            },
        "mcp-obsidian": {
            "type": "stdio",
            "command": "uvx",
            "args": [
                "mcp-obsidian"
            ],
            "env": {
                "OBSIDIAN_API_KEY": "op://Personal/Obsidian-Local-API/Section_hsleijvcfhz4pcnydtfyn5sywy/api key"
            }
        }
        }
    }
